# URL del backend Django. El navegador llama directo a este origen; para auth
# (real desde F4-A) el backend debe permitir CORS con credenciales (ver README).
NEXT_PUBLIC_API_URL=http://localhost:8050

# Control de los mocks:
#   enabled  -> MSW intercepta todo MENOS auth (login/refresh/logout van al
#               backend real; las rutas mockeadas siguen sirviéndose localmente)
#   disabled -> toda la red va al backend real (NEXT_PUBLIC_API_URL)
NEXT_PUBLIC_API_MOCKING=enabled

# WhatsApp Embedded Signup (Meta) — usados en el paso 7 del onboarding (F4-C).
# NEXT_PUBLIC_META_APP_ID = App ID de Meta (FB.init).
# NEXT_PUBLIC_META_CONFIG_ID = configuration_id del Embedded Signup (FB.login).
# Públicos por diseño; NO son secretos. META_APP_SECRET vive SOLO en el backend
# y nunca llega al cliente: del navegador solo viaja el `code` corto al callback.
# Si quedan vacíos, el paso 7 muestra un aviso de configuración en vez del botón.
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=
