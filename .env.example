# URL del backend Django. En modo mock, MSW intercepta estas mismas rutas;
# al conectar el backend real se apunta aquí.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Control de los mocks:
#   enabled  -> MSW intercepta toda la red (desarrollo mock-first)
#   disabled -> las llamadas van al backend real (NEXT_PUBLIC_API_URL)
NEXT_PUBLIC_API_MOCKING=enabled

# WhatsApp Embedded Signup (Meta). Se usan desde F4-C.
# NO son secretos: META_APP_SECRET jamás llega al cliente.
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=
